code = "shader_type canvas_item;
render_mode blend_mix;

uniform float FloatParameter = 0;
uniform sampler2D NoiseTexture;



void fragment() {
// FloatParameter:8
	float n_out8p0 = FloatParameter;


// MultiplyAdd:9
	float n_in9p1 = 1.00000;
	float n_in9p2 = 0.10000;
	float n_out9p0 = fma(n_out8p0, n_in9p1, n_in9p2);


	vec4 n_out5p0;
// Texture2D:5
	n_out5p0 = texture(NoiseTexture, UV);
	float n_out5p1 = n_out5p0.r;


// SmoothStep:7
	float n_out7p0 = smoothstep(n_out8p0, n_out9p0, n_out5p1);


// Output:0
	COLOR.a = n_out7p0;


}
