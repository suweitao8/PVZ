[sub_resource type="GDScript" id="GDScript_mleul"]
script/source = "extends Node2D



var isKeyDown: bool = false

var curShakes: float = 0
var maxShakeT: float = 1.5
var shakeDelayT: float = .5

var shake_duration = 2.0  # The duration of the screen shake in seconds
var shake_amplitude = 10.0  # The intensity of the shake





# Called when the node enters the scene tree for the first time.
func _ready():
    pass





# Called every frame. 'delta' is the elapsed time since the previous frame.
func _process(_delta):
    if( Input.is_key_pressed(KEY_A)):
        if(!isKeyDown):
            attack()
        isKeyDown = true;
    else:
        isKeyDown = false;
    applyShake(_delta);




func attack():
    curShakes = maxShakeT + shakeDelayT;




# this is a super jenk way to make the screen shake. It actually doesn't make the screen shake, so yeah...
func applyShake(_delta):
    curShakes -= _delta
    if ( curShakes > 0 && curShakes < maxShakeT):
        var x = randf_range(-10, 10)
        var y = randf_range(-10, 10)
        var newPos = Vector2(x, y)
        position = newPos
    else:
        position = Vector2()



            



"

[sub_resource type="GDScript" id="GDScript_6hcqp"]
script/source = "extends SpineSprite


#Vars-----------------------------


@export var id: int
@export var particleGravity: Vector2
@export var particleSpeedScale: float
@export var particleVelocityMinMax: Vector2
#@export var myParticles: Array[String]
@export var damageParticleNodes: Array[NodePath]
#@export var splatParticleNodes: Array[NodePath]
@export var sprayNodes: Array[NodePath]
\\



var IDLE_LOOP:  String = \"idle_loop\"
var DEAD_LOOP: String = \"dead_loop\"
var ATTACK: String = \"_ignore/attack\"
var HURT: String  = \"hurt\"
var SHRIVEL: String = \"wither\"
var REGENERATE: String = \"regenerate\"
var WRITHE_LOOP: String = \"_ignore/writhe_loop\"
var isDead: bool = false
var isKeyDown: bool = false
var myDieKey: int    
var myHurtKey: int
var attackKey: int = KEY_A

var animState:  SpineAnimationState




# Called when the node enters the scene tree for the first time.
func _ready():
    if ( id == 1):
        myDieKey = KEY_1
        myHurtKey = KEY_4
    if ( id == 2):
        myDieKey = KEY_2
        myHurtKey = KEY_5
    if ( id == 3):
        myDieKey = KEY_3
        myHurtKey = KEY_6
        
    animState = get_animation_state() 
    animation_event.connect(_animation_event)
    playAnimation(WRITHE_LOOP, 0.0, 1)
    playAnimation(IDLE_LOOP);

    for ref in sprayNodes:
        get_node(ref).visible = false;


func _exit_tree():
    animation_event.disconnect(_animation_event)


# Called every frame. 'delta' is the elapsed time since the previous frame.
func _process(_delta):
    
    if (Input.is_key_pressed(myDieKey)):
        if(!isKeyDown):
            isDead = !isDead
            if (isDead):
                shrivel()
            else:
                regenerate()
            #print(\"isDead is now \", isDead)
            isKeyDown = true


    elif(Input.is_key_pressed(myHurtKey)):
        if(!isKeyDown):
            hurt()
            isKeyDown = true
            

    
    elif(Input.is_key_pressed(attackKey)):
        if(!isKeyDown):
            attack()

    else:
        isKeyDown = false;
    



func attack():
    playAnimation(ATTACK, 0.4, 1)
    queueAnimation(WRITHE_LOOP, 0.05, 1)




func hurt():
    playAnimation(HURT, .05, 0, false)
    queueAnimation(IDLE_LOOP, 0.2)




func shrivel():
    playAnimation(SHRIVEL, .1, 0, false)
    queueAnimation(DEAD_LOOP, .1)


    


func regenerate():
    playAnimation(REGENERATE, .1, 0, false)
    queueAnimation(IDLE_LOOP, .1);
    for ref in sprayNodes:
        get_node(ref).visible = true;
        get_node(ref).material.set_shader_parameter(\"direction\", -1)
        var endScale: Vector2 = get_node(ref).scale
        get_node(ref).scale = Vector2()
        var tw: Tween = create_tween()
        tw.set_parallel(true)
        var randTime = randf_range(0, .5) 
        get_node(ref).material.set_shader_parameter(\"opacity\", .5)
        tw.tween_property(get_node(ref), \"scale\", endScale, randTime + .5).set_ease(Tween.EASE_OUT).set_trans(Tween.TRANS_EXPO)
        #print(\"material ref \", get_node(ref).material.get_shader_parameter(\"opacity\"))
        var mat: Material = get_node(ref).material
        tw.tween_property(mat, \"shader_parameter/opacity\", .9, randTime).set_ease(Tween.EASE_OUT).set_trans(Tween.TRANS_EXPO)



func playAnimation(anim: String, blend: float = 0, track: int = 0, loop:bool = true) -> SpineTrackEntry:
    var te: SpineTrackEntry = animState.set_animation(anim, loop, track)
    te.set_mix_duration(blend)
    return te
    
    
    
func queueAnimation(anim: String, blend: float = 0, track: int = 0, loop:bool = true) -> SpineTrackEntry:
    var te: SpineTrackEntry = animState.add_animation(anim, 0, loop, track)
    te.set_mix_duration(blend)
    return te




func _animation_event(_spine_sprite: Object, _animation_state: Object, _track_entry: Object, _event: Object):
    print(\"an event has landed \", _event.get_data().get_event_name())
    if (_event.get_data().get_event_name() == \"explode\"):
        for ref in damageParticleNodes:
            #print(\"the damn thing is \", ref) \\
            get_node(ref).gravity = particleGravity
            get_node(ref).speed_scale = particleSpeedScale
            get_node(ref).initial_velocity_min = particleVelocityMinMax.x
            get_node(ref).initial_velocity_max = particleVelocityMinMax.y
            get_node(ref).restart()

        



    elif  (_event.get_data().get_event_name() == \"pre-explode\"):
        pass
        # Don't need this any more #########
        # print(\"PRE EXPLODE CALLED\")
        # for ref in sprayNodes:
        # 	var startScale: Vector2 = get_node(ref).scale
        # 	var tw: Tween = create_tween()
        # 	var randTime = randf_range(0, .35) + .4
        # 	tw.tween_property(get_node(ref), \"scale\", Vector2(.01, .25), randTime).set_ease(Tween.EASE_IN).set_trans(Tween.TRANS_QUAD)
        # 	tw.tween_property(get_node(ref), \"visible\", false, 0)
        # 	tw.tween_property(get_node(ref), \"scale\", startScale, 0)


    elif  (_event.get_data().get_event_name() == \"suck_complete\"):
        for ref in sprayNodes:
            var startScale: Vector2 = get_node(ref).scale
            var tw: Tween = create_tween()
            var randTime = randf_range(0, .35) + .4
            tw.tween_property(get_node(ref), \"scale\", Vector2(.01, .25), randTime).set_ease(Tween.EASE_IN).set_trans(Tween.TRANS_QUAD)
            tw.tween_property(get_node(ref), \"visible\", false, 0)
            tw.tween_property(get_node(ref), \"scale\", startScale, 0)



func hideSpray(spray: Node2D):
    spray.visible = false

    
"

